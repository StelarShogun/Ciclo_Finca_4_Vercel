APP_NAME="Ciclo Finca"
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_URL=https://ciclo-finca-4-app-4ccw.onrender.com
# URL del SPA Next (storefront). En dev: http://localhost:3000. Usada por el callback OAuth para volver al frontend.
SPA_URL=http://localhost:3000

# Public URL for transactional emails and absolute links (defaults to APP_URL if unset).
# Must also be set on queue workers / cron containers so mail links are not localhost.
# Con el frontend Next separado, apunta al dominio del SPA.
# FRONTEND_URL=https://app.ciclo-finca.com

# --- API + Sanctum SPA (frontend Next.js) ---
# Dominios cuyo origen es "de confianza" para la cookie de sesión. En prod usar
# el(los) dominio(s) del SPA; en dev incluir localhost:3000.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
# Dominio padre compartido para que la cookie viaje entre app. y api. (prod).
# En local dejar vacío. Ej prod: .ciclo-finca.com
SESSION_DOMAIN=
# Orígenes permitidos por CORS (coma-separados). supports_credentials=true.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: protects /run-migrations and /run-seeders in production (?key=...)
# DEPLOY_SECRET=

# Puerto de `npm run dev` (Vite). Por defecto 5173. Opcional: VITE_PORT=8080 si liberas el puerto (p. ej. sin Docker en 8080).
# VITE_PORT=5173

DB_CONNECTION=mysql
# Docker Compose (este repo): db_ciclo o db (alias). Solo resuelve DENTRO de la red de Compose.
# Si ejecutas `php artisan` en el HOST (fuera del contenedor), usa DB_HOST=127.0.0.1 y DB_PORT=3307
# mientras `docker compose up` esté levantado (MySQL publicado en 3307:3306). O bien: docker compose exec app_ciclo php artisan …
# Local sin Docker: 127.0.0.1 y el puerto donde escuche tu MySQL.
# Aiven / producción: host sin protocolo
DB_HOST=
# Aiven usa un puerto propio (ej. 10163), no 3306
DB_PORT=3306
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
# Contraseña: configurarla solo en Render Environment, no commitear
DB_PASSWORD=

# Queue driver — must be "database" in production so email/notification jobs run in the
# background queue worker (docker-entrypoint.sh launches queue:work automatically).
# Using "sync" causes SMTP calls to block HTTP responses (~15 s on Render cold starts).
QUEUE_CONNECTION=database

# Application monitoring dashboard at /pulse (admin session required).
PULSE_ENABLED=true

CACHE_STORE=file

# Sessions: prefer database on multi-instance hosts (requires migrated `sessions` table — database/migrations/0002_sessions.php).
# Plan B if DB unavailable: SESSION_DRIVER=cookie (signed cookies, ~4KB limit).
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
# Minutes before an idle session expires. 10080 = 1 week.
# Render free-tier containers sleep after inactivity; a long lifetime prevents
# admins from being logged out when the dyno wakes up. Keep APP_KEY stable
# in the Render dashboard so session cookies remain valid across restarts.
SESSION_LIFETIME=10080

# Pedidos "listo para recoger": horas desde ready_at antes de cancelación automática (orders:cancel-expired-ready).
READY_TO_PICKUP_EXPIRATION_HOURS=72

# Google OAuth — GOOGLE_REDIRECT_URI must match Google Cloud Console exactly (usually APP_URL + /auth/google/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Laravel Pulse — dashboard at /pulse (admin session required via viewPulse gate).
PULSE_ENABLED=true
PULSE_PATH=pulse
# PULSE_DOMAIN=
# PULSE_DB_CONNECTION=
