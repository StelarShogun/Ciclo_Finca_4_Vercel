# Copia a `.env.testing` y ajusta credenciales (mismas que en `.env` para Docker).
# Tests en el host: MySQL expuesto en 127.0.0.1:3307 (docker-compose 3307:3306).

APP_NAME="Ciclo Finca"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Mismo criterio que phpunit.xml: fechas en tests alineadas con el accessor UTC del modelo Sale
APP_TIMEZONE=UTC

# Integración MySQL en el host (puerto 3307). La suite por defecto usa SQLite :memory:
# (phpunit.xml); si combinás mysql en .env.testing con :memory:, Tests\TestCase alinea la conexión.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=laravel_test
DB_USERNAME=
DB_PASSWORD=

BCRYPT_ROUNDS=4
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
