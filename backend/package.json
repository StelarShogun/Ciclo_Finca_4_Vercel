{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "ciclo-finca-4-app",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build --configLoader runner",
        "build:fa-subset": "node scripts/fonts/build-fa-subset.mjs",
        "dev": "vite",
        "typecheck": "tsc -b --force",
        "typecheck:legacy": "tsc -p tsconfig.legacy-dom.json --noEmit",
        "serve:php": "serve.cmd",
        "k6:home": "bash scripts/k6/run-homepage.sh",
        "unlighthouse": "bash scripts/unlighthouse/run.sh guest",
        "unlighthouse:guest": "bash scripts/unlighthouse/run.sh guest",
        "unlighthouse:client": "bash scripts/unlighthouse/run.sh client",
        "unlighthouse:admin": "bash scripts/unlighthouse/run.sh admin",
        "unlighthouse:auth": "bash scripts/unlighthouse/run-auth.sh",
        "test:e2e:setup": "playwright test --project=setup",
        "test:e2e": "playwright test --project=chromium",
        "test:e2e:report": "playwright show-report",
        "test:api": "newman run postman/CF4-Storefront-API.postman_collection.json --env-var baseUrl=${API_BASE_URL:-http://localhost:8080}",
        "test:api:docker": "newman run postman/CF4-Storefront-API.postman_collection.json --env-var baseUrl=http://127.0.0.1",
        "test:seguimiento8:evidence": "bash scripts/run-seguimiento-8-evidence.sh"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.0",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "newman": "^6.2.1",
        "tailwindcss": "^4.0.0",
        "unlighthouse": "^0.17.9",
        "vite": "^7.3.2"
    },
    "dependencies": {
        "@fontsource/dm-sans": "^5.2.8",
        "@fontsource/poppins": "^5.2.7",
        "@fortawesome/fontawesome-free": "^6.7.2",
        "@vercel/analytics": "^2.0.1",
        "@vercel/blob": "^2.4.1",
        "@vercel/speed-insights": "^2.0.0",
        "chart.js": "^4.5.1",
        "framer-motion": "^12.41.0",
        "gsap": "^3.15.0",
        "sweetalert2": "^11.23.0",
        "swiper": "^12.1.4",
        "typescript": "^6.0.3"
    }
}
