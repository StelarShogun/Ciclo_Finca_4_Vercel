{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "composite": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "paths": {
      "@/*": ["resources/ts/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "tsBuildInfoFile": ".vite-cache/tsconfig.legacy-dom.tsbuildinfo",
    "types": ["vite/client"]
  },
  "include": [
    "resources/ts/admin/**/*.ts",
    "resources/ts/client/**/*.ts",
    "resources/ts/errors/scenes.ts",
    "resources/ts/errors/scenes/*.ts",
    "resources/ts/shared/client-pagination.ts",
    "resources/ts/shared/legacy-dom.ts",
    "resources/ts/shared/escape-html.ts",
    "resources/ts/types/legacy-globals.d.ts",
    "resources/ts/types/legacy-client-modules.d.ts"
  ],
  "exclude": [
    "resources/ts/admin/login/login.ts",
    "resources/ts/client/header-menu-alert.ts",
    "resources/ts/client/checkout-copy.ts"
  ]
}
