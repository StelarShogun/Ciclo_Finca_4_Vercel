{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "composite": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/client/bundles/catalog": ["resources/ts/types/shims/legacy-dynamic-imports.d.ts"],
      "@/client/clients-catalog-heartbeat": ["resources/ts/types/shims/legacy-dynamic-imports.d.ts"],
      "@/client/header-catalog-search": ["resources/ts/types/shims/legacy-dynamic-imports.d.ts"],
      "@/client/swal": ["resources/ts/types/shims/legacy-dynamic-imports.d.ts"],
      "@/*": ["resources/ts/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client"]
  },
  "include": [
    "resources/ts/**/*.tsx",
    "resources/ts/app.tsx",
    "resources/ts/bootstrap.ts",
    "resources/ts/shared/**/*.ts",
    "resources/ts/features/**/*.ts",
    "resources/ts/Pages/**/*.tsx",
    "resources/ts/Pages/**/*.ts",
    "resources/ts/types/**/*.d.ts",
    "resources/ts/types/**/*.ts",
    "resources/ts/client/header-menu-alert.ts",
    "resources/ts/types/shims/**/*.d.ts",
    "resources/ts/shared/legacy-dom.ts"
  ],
  "exclude": [
    "resources/ts/admin/**",
    "resources/ts/client/**",
    "resources/ts/errors/scenes/wrong-route.ts",
    "resources/ts/shared/ajax-pagination.ts",
    "resources/ts/shared/client-pagination.ts"
  ]
}
