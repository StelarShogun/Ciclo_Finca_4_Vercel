includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon

parameters:
    paths:
        - app
        - database/factories
        - database/seeders
        - tests

    level: 5

    tmpDir: .phpstan-cache

    # PHPDoc de modelos Eloquent (p. ej. status) vs valores en inglés en código
    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        -
            message: '#view expects view-string#'

    reportUnmatchedIgnoredErrors: false
