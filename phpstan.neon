includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon

parameters:
    paths:
        - app
        - database/factories
        - database/seeders
        - tests

    level: 5

    tmpDir: .phpstan-cache

    # PHPDoc de modelos Eloquent (p. ej. status) vs valores en inglés en código
    treatPhpDocTypesAsCertain: false

    # Larastan: this codebase relies heavily on Eloquent's dynamic properties.
    # In CI we want actionable findings without being blocked by missing @property PHPDoc.
    checkModelProperties: false

    universalObjectCratesClasses:
        - Illuminate\Database\Eloquent\Model

    ignoreErrors:
        -
            message: '#view expects view-string#'
        -
            message: '#Using nullsafe (property|method) access .* is unnecessary\\. Use -> instead\\.#'
        -
            message: '#Method .* is unused\\.#'
        -
            message: "#Relation '.*' is not found in .* model\\.#"
        -
            message: '#Call to an undefined method App\\\\Services\\\\InventoryMovementService::recordRefund\\(\\)\\.#'
        -
            message: '#Call to an undefined method Illuminate\\\\Database\\\\Eloquent\\\\Builder::notExpired\\(\\)\\.#'
        -
            message: '#Method Illuminate\\\\Testing\\\\TestResponse<.*>::json\\(\\) invoked with 2 parameters, 0-1 required\\.#'
        -
            message: '#should return Illuminate\\\\Http\\\\Response but returns Symfony\\\\Component\\\\HttpFoundation\\\\Response\\.#'
        -
            message: '~Parameter #1 .*callback of method Illuminate\\\\Database\\\\Eloquent\\\\Collection<.*>::map\\(\\) .*~'

    reportUnmatchedIgnoredErrors: false
