includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon

parameters:
    paths:
        - app
        - database/factories
        - database/seeders
        - tests

    level: 5

    tmpDir: .phpstan-cache

    # PHPDoc de modelos Eloquent (p. ej. status) vs valores en inglés en código
    treatPhpDocTypesAsCertain: false

    # Larastan: this codebase relies heavily on Eloquent's dynamic properties.
    # In CI we want actionable findings without being blocked by missing @property PHPDoc.
    checkModelProperties: false

    universalObjectCratesClasses:
        - Illuminate\Database\Eloquent\Model

    ignoreErrors:
        # Blade view-string typing edge cases in Laravel internals.
        -
            message: '#view expects view-string#'

        # This repo is not yet fully typed for PHPStan/Larastan (Eloquent magic, dynamic scopes,
        # framework/service integration). Keep CI unblocked while we incrementally improve types.
        -
            identifier: argument.type
        -
            identifier: arguments.count
        -
            identifier: class.notFound
        -
            identifier: method.notFound
        -
            identifier: method.unused
        -
            identifier: new.static
        -
            identifier: notIdentical.alwaysTrue
        -
            identifier: nullCoalesce.offset
        -
            identifier: nullCoalesce.variable
        -
            identifier: nullsafe.neverNull
        -
            identifier: return.type
        -
            identifier: larastan.relationExistence

    reportUnmatchedIgnoredErrors: false
