{
  "info": {
    "_postman_id": "cf4-storefront-api-seguimiento-8",
    "name": "CF4 Storefront API",
    "description": "Public API endpoints for Ciclo Finca 4 — Newman / Postman (Seguimiento 8).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Health — GET /up",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/up"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Suggestions — short search",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/products/suggestions?search=a",
          "host": ["{{baseUrl}}"],
          "path": ["api", "products", "suggestions"],
          "query": [{ "key": "search", "value": "a" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Empty suggestions', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('suggestions');",
              "    pm.expect(json.suggestions).to.be.an('array');",
              "    pm.expect(json.suggestions).to.have.lengthOf(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Catalog heartbeat",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/catalog/heartbeat"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Has version', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('version');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Search trending",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/catalog/search-trending?limit=5",
          "host": ["{{baseUrl}}"],
          "path": ["api", "catalog", "search-trending"],
          "query": [{ "key": "limit", "value": "5" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('JSON shape', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('period');",
              "    pm.expect(json).to.have.property('products');",
              "    pm.expect(json).to.have.property('terms');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
