# Monorepo root — las reglas de Laravel viven en backend/.gitignore
# y las de Next vivirán en frontend/.gitignore.

# Frontend (Next.js) build/deps — por si algo se crea en la raíz del frontend
/frontend/node_modules
/frontend/.next
/frontend/out
/frontend/.vercel

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# .env raíz (symlink a backend/.env para docker compose)
/.env

# Seguridad extra contra el bloat que metió GitHub Desktop en Dev:
# build/deps/caché del backend (las reglas reales viven en backend/.gitignore).
/backend/node_modules
/backend/public/build
/backend/storage/framework/cache/data
.vercel
