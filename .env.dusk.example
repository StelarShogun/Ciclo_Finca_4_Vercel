# Copy to .env.dusk.local (gitignored) before running Laravel Dusk.
# Dusk drives a real browser against the running app — not the in-memory PHPUnit stack.

APP_URL=http://localhost:8080

DB_CONNECTION=mysql
# Host machine → Docker MySQL published on 3307 (see docker-compose.yml).
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=laravel_test
DB_USERNAME=root
DB_PASSWORD=root

# Disable reCAPTCHA so login/register forms submit in the browser.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

DUSK_DRIVER_URL=http://localhost:9515
