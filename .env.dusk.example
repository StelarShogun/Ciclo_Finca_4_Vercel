# Dusk environment (copy to .env.dusk.local for host runs, or use the Docker script).
#
# Recommended (Docker — no local Composer/Chrome):
#   ./scripts/run-dusk-docker.sh
#
# Manual host run (Chrome/Chromium + Composer on your machine):
#   cp .env.dusk.example .env.dusk.local
#   # Set APP_KEY from your .env
#   npm run build
#   composer run dusk
#
# APP_URL / DB_* below are for host → Docker port mappings (8080, 3307).

APP_NAME="Ciclo Finca"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

DUSK_DRIVER_URL=http://localhost:9515
# Set to true when recording the Seguimiento 8 video (visible Chrome window).
DUSK_HEADLESS_DISABLED=false

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=laravel_dusk
DB_USERNAME=laravel
DB_PASSWORD=password

SESSION_DRIVER=database
CACHE_STORE=file
QUEUE_CONNECTION=sync
MAIL_MAILER=log
PULSE_ENABLED=true
# Leave empty so Dusk can submit login forms without reCAPTCHA.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
