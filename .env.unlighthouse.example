# Copy to .env.unlighthouse.local (gitignored) and fill secrets for local scans only.
# Docs: docs/UNLIGHTHOUSE.md

UNLIGHTHOUSE_SITE=http://localhost:8080
UNLIGHTHOUSE_DEBUG=1

# Chrome for Puppeteer/Lighthouse (install: npx @puppeteer/browsers install chrome@stable)
# UNLIGHTHOUSE_CHROME_PATH=/home/you/.cache/puppeteer/chrome/linux-.../chrome-linux64/chrome

# Guest scan: product detail path (get id via artisan tinker on active product)
UNLIGHTHOUSE_PRODUCT_PATH=/product/1

# Laravel session cookie name (default: ciclo-finca-session from APP_NAME)
# UNLIGHTHOUSE_SESSION_COOKIE=ciclo-finca-session

# Client: programmatic login (only if RECAPTCHA_SITE_KEY is empty in .env)
UNLIGHTHOUSE_CLIENT_EMAIL=darwinn990@gmail.com
UNLIGHTHOUSE_CLIENT_PASSWORD=

# Client: alternative — paste session cookie after manual login at /login
# Format: ciclo-finca-session=eyJ... or raw value only
UNLIGHTHOUSE_CLIENT_COOKIE=
# UNLIGHTHOUSE_CLIENT_XSRF_TOKEN=

# Client scan URLs (no crawler): /, /catalog, /cart, /profile, /invoices, UNLIGHTHOUSE_PRODUCT_PATH

# Admin: required for npm run unlighthouse:admin (reCAPTCHA blocks auto-login)
# Option A — generate locally (APP_ENV=local only):
#   docker exec laravel_app_ciclo php artisan unlighthouse:admin-cookie
# Option B — DevTools → Application → Cookies → copy Value (or full "name=value")
#   ciclo-finca-session + XSRF-TOKEN (both recommended)
UNLIGHTHOUSE_ADMIN_COOKIE=
UNLIGHTHOUSE_ADMIN_XSRF_TOKEN=

# Set to 1 to pass --no-cache to Unlighthouse (fresh Lighthouse run)
# UNLIGHTHOUSE_NO_CACHE=1
