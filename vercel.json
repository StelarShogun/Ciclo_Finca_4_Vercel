{
    "version": 2,
    "installCommand": "npm ci",
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0",
            "excludeFiles": "{storage/**,tests/**,docs/**,database/**,node_modules/**,vendor/aws/aws-sdk-php/src/data/**}"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/fonts/(.*)",
            "dest": "/public/fonts/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/manifest.webmanifest",
            "dest": "/public/manifest.webmanifest"
        },
        {
            "src": "/site.webmanifest",
            "dest": "/public/site.webmanifest"
        },
        {
            "src": "/favicon.svg",
            "dest": "/public/favicon.svg"
        },
        {
            "src": "/favicon-32x32.png",
            "dest": "/public/favicon-32x32.png"
        },
        {
            "src": "/favicon-16x16.png",
            "dest": "/public/favicon-16x16.png"
        },
        {
            "src": "/apple-touch-icon.png",
            "dest": "/public/apple-touch-icon.png"
        },
        {
            "src": "/android-chrome-192x192.png",
            "dest": "/public/android-chrome-192x192.png"
        },
        {
            "src": "/android-chrome-512x512.png",
            "dest": "/public/android-chrome-512x512.png"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "crons": [
        {
            "path": "/internal/vercel/cron/scheduler",
            "schedule": "0 3 * * *"
        }
    ]
}
