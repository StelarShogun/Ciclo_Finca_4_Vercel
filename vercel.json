{
    "version": 2,
    "framework": null,
    "buildCommand": "composer install --no-dev --prefer-dist --no-interaction --optimize-autoloader && npm ci && npm run build && php artisan config:cache",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4",
            "maxDuration": 60
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "crons": [
        {
            "path": "/internal/vercel/cron/scheduler",
            "schedule": "*/15 * * * *"
        }
    ]
}
