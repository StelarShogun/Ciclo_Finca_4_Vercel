{
    "version": 2,
    "installCommand": "npm ci",
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0",
            "excludeFiles": "{storage/**,tests/**,docs/**,database/**,node_modules/**,vendor/aws/aws-sdk-php/src/data/**}"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "crons": [
        {
            "path": "/internal/vercel/cron/scheduler",
            "schedule": "0 3 * * *"
        }
    ]
}
