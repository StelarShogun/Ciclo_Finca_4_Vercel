APP_NAME="Ciclo Finca"
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_URL=https://ciclo-finca-4-app-4ccw.onrender.com

DB_CONNECTION=mysql
# Aiven: host sin protocolo, ej. mysql-xxxxx-ciclofinca4.j.aivencloud.com
