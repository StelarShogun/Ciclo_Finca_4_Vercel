APP_NAME="Ciclo Finca"
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_URL=https://ciclo-finca-4-app-4ccw.onrender.com

# Optional: protects /run-migrations and /run-seeders in production (?key=...)
# DEPLOY_SECRET=

# Puerto de `npm run dev` (Vite). Por defecto 5173. Opcional: VITE_PORT=8080 si liberas el puerto (p. ej. sin Docker en 8080).
# VITE_PORT=5173

DB_CONNECTION=mysql
# Docker Compose (este repo): db_ciclo o db (alias). Solo resuelve DENTRO de la red de Compose.
# Si ejecutas `php artisan` en el HOST (fuera del contenedor), usa DB_HOST=127.0.0.1 y DB_PORT=3307
# mientras `docker compose up` esté levantado (MySQL publicado en 3307:3306). O bien: docker compose exec app_ciclo php artisan …
# Local sin Docker: 127.0.0.1 y el puerto donde escuche tu MySQL.
# Aiven / producción: host sin protocolo
DB_HOST=
# Aiven usa un puerto propio (ej. 10163), no 3306
DB_PORT=3306
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
# Contraseña: configurarla solo en Render Environment, no commitear
DB_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=file

# Google OAuth (login social)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
